{
  "name": "atlas-os",
  "version": "0.1.10",
  "description": "Atlas OS — desktop control panel for AI tools (macOS)",
  "private": true,
  "type": "module",
  "main": "./out/main/index.cjs",
  "author": "Roman Neganov",
  "license": "MIT",
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=9"
  },
  "volta": {
    "node": "22.22.1",
    "pnpm": "9.15.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "electron-vite dev --watch",
    "build": "pnpm typecheck && electron-vite build",
    "dist": "pnpm build && electron-builder --mac",
    "start": "electron-vite preview",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "typecheck:web": "tsc -p tsconfig.web.json --noEmit",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:web",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint && pnpm typecheck",
    "pre-push": "node scripts/prepush-version-bump.mjs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.201",
    "@dnd-kit/core": "^6.3.1",
    "@fontsource/geist-mono": "^5.2.8",
    "@fontsource/geist-sans": "^5.2.5",
    "@gsap/react": "^2.1.2",
    "@number-flow/react": "^0.6.1",
    "@trpc/server": "^11.17.0",
    "better-sqlite3": "^12.10.0",
    "d3-force": "^3.0.0",
    "d3-force-3d": "^3.0.6",
    "drizzle-orm": "^0.45.2",
    "electron-log": "^5.4.4",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "gsap": "^3.15.0",
    "js-yaml": "^4.1.1",
    "katex": "^0.17.0",
    "motion": "^12.42.2",
    "react-force-graph-2d": "^1.29.1",
    "react-force-graph-3d": "^1.29.1",
    "react-katex": "^3.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "three": "^0.185.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@electron/rebuild": "^4.0.4",
    "@hookform/resolvers": "^5.4.0",
    "@playwright/test": "^1.60.0",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.100.11",
    "@trpc/client": "^11.17.0",
    "@trpc/react-query": "^11.17.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/d3-force": "^3.0.10",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/react-katex": "^3.0.4",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^5.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.10",
    "electron": "~38.8.6",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.0",
    "recharts": "^3.8.1",
    "simple-git-hooks": "^2.13.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.3",
    "vitest": "^4.1.7",
    "zustand": "^5.0.13"
  }
}
